{
  "settings": {
    "analysis": {
      "normalizer": {
        "lc": {
          "type": "custom",
          "filter": [
            "lowercase",
            "asciifolding"
          ]
        }
      },
      "tokenizer": {
        "edge_ngram_tokenizer": {
          "type": "edge_ngram",
          "min_gram": 2,
          "max_gram": 15,
          "token_chars": [
            "letter",
            "digit"
          ]
        }
      },
      "analyzer": {
        "edge_ngram_analyzer": {
          "tokenizer": "edge_ngram_tokenizer",
          "filter": [
            "lowercase"
          ]
        },
        "edge_ngram_search_analyzer": {
          "tokenizer": "standard",
          "filter": [
            "lowercase"
          ]
        }
      }
    }
  },
  "mappings": {
    "properties": {
      "canonical_key": { "type": "keyword" },
      "brand": { "type": "keyword" },
      "title": { "type": "text" },
      "size": { "type": "keyword" },
      "embedding": {
                    "type": "dense_vector",
                    "dims": 384,
                    "index": true,
                    "similarity": "cosine"
                },
      "items": {
        "type": "nested",
        "properties": {
          "id":          { "type": "keyword" },
          "canonical_id": { "type":  "keyword" },
          "marketplace_code": { "type": "text" ,
                        "analyzer": "edge_ngram_analyzer",
                        "search_analyzer": "edge_ngram_search_analyzer",
                        "fields": {
                            "raw": {"type": "keyword"}
                        }
                     },
          "source_item_id": {"type":  "text"},
          "title":       { "type": "text" },
          "brand":       { "type": "text",
                            "fields": { "keyword": { "type": "keyword", "normalizer": "lc" } }
                         },
          "condition":   { "type": "keyword" },
          "price_cents": { "type": "integer" },
          "currency":    { "type": "keyword" },
          "image_url":   { "type": "keyword", "index": false },
          "seller_urls": { "type": "keyword" },
          "category":    { "type": "keyword" },
          "size":        { "type": "keyword" },
          "color":       { "type": "text",
                            "fields": { "keyword": { "type": "keyword", "normalizer": "lc" } }
                         }
        }
      }
    }
  }
}